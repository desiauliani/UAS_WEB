<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container py-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 text-center">
                <img src="/images/avatar-placeholder.png" class="rounded-circle mb-3 mx-auto" style="width: 120px; height: 120px; object-fit: cover;">
                <h5 class="fw-bold"><%= user.nama %></h5>
                <p class="text-muted"><%= user.email %></p>
                <hr>
                <div class="d-grid gap-2">
                    <a href="/auth/logout" class="btn btn-outline-danger btn-sm">Keluar</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h4 class="fw-bold mb-4" style="color: var(--color-rosegold);">Riwayat Pesanan</h4>
                <% if (user.orders && user.orders.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ID Pesanan</th>
                                    <th>Status</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% user.orders.forEach(order => { %>
                                    <tr>
                                        <td>#ORD-<%= order.id %></td>
                                        <td><span class="badge bg-light text-dark"><%= order.status %></span></td>
                                        <td>Rp <%= order.total.toLocaleString('id-ID') %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-muted">Belum ada riwayat pesanan.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>