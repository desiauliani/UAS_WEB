<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container py-5 fade-in">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h3 style="font-family: 'Playfair Display', serif; color: var(--color-rosegold);">
                Riwayat Pesanan Saya
            </h3>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/catalog" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-flower1"></i> Belanja Lagi
            </a>
        </div>
    </div>

    <% if (orders && orders.length > 0) { %>
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: var(--color-softpink);">
                        <tr>
                            <th class="py-3 px-4 font-weight-normal text-muted">ID Pesanan</th>
                            <th class="py-3 font-weight-normal text-muted">Tanggal</th>
                            <th class="py-3 font-weight-normal text-muted">Total Belanja</th>
                            <th class="py-3 font-weight-normal text-muted">Status</th>
                            <th class="py-3 font-weight-normal text-muted text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td class="px-4 fw-bold">#ORD-<%= order.id %></td>
                                <td><%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
                                <td class="fw-bold" style="color: var(--color-rosegold);">Rp <%= order.total.toLocaleString('id-ID') %></td>
                                <td>
                                    <% 
                                        let badgeClass = 'bg-secondary';
                                        if(order.status === 'Pending') badgeClass = 'bg-warning text-dark';
                                        if(order.status === 'Diproses') badgeClass = 'bg-info text-dark';
                                        if(order.status === 'Dikirim') badgeClass = 'bg-primary';
                                        if(order.status === 'Selesai') badgeClass = 'bg-success';
                                        if(order.status === 'Dibatalkan') badgeClass = 'bg-danger';
                                    %>
                                    <span class="badge <%= badgeClass %> rounded-pill px-3 py-2"><%= order.status %></span>
                                </td>
                                <td class="text-center">
                                    <a href="/orders/detail/<%= order.id %>" class="btn btn-sm btn-light border rounded-pill px-3">
                                        Lihat Detail
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } else { %>
        <div class="text-center py-5 rounded-4 bg-white shadow-sm slide-up">
            <i class="bi bi-receipt display-1 text-muted opacity-25"></i>
            <h4 class="mt-4 text-muted">Belum ada pesanan</h4>
            <p class="text-muted mb-0">Anda belum melakukan transaksi apapun. Yuk mulai pilih bunga favoritmu!</p>
        </div>
    <% } %>
</div>

<%- include('../layouts/footer') %>