<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container py-5 fade-in">
    <div class="text-center mb-5">
        <h2 style="font-family: 'Playfair Display', serif; color: var(--color-rosegold);">
            Penyelesaian Pesanan
        </h2>
        <p class="text-muted">Selesaikan pembayaran agar pesanan Anda segera diproses</p>
    </div>

    <form action="/orders/checkout" method="POST" enctype="multipart/form-data">
        <div class="row">
            <!-- Informasi Pembayaran & Pengiriman -->
            <div class="col-lg-7 mb-4">
                <div class="checkout-box">
                    <h5><i class="bi bi-wallet2 me-2" style="color: var(--color-rosegold);"></i> Metode Pembayaran</h5>
                    <p class="text-muted small mb-4">Silakan transfer sesuai dengan total tagihan ke salah satu rekening berikut:</p>
                    
                    <div class="row g-3 mb-4 text-center">
                        <div class="col-sm-6">
                            <div class="p-3 border rounded-3 bg-light">
                                <h6 class="fw-bold mb-1">BCA</h6>
                                <p class="mb-0 text-muted">1234 5678 90</p>
                                <small class="text-muted">a.n. Rhopaloceraz Florist</small>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 border rounded-3 bg-light">
                                <h6 class="fw-bold mb-1">Mandiri</h6>
                                <p class="mb-0 text-muted">0987 6543 21</p>
                                <small class="text-muted">a.n. Rhopaloceraz Florist</small>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium">Pilih Bank Asal</label>
                        <select name="metode_pembayaran" class="form-select bg-light" required>
                            <option value="">-- Pilih Metode Pembayaran --</option>
                            <option value="Transfer BCA">Transfer BCA</option>
                            <option value="Transfer Mandiri">Transfer Mandiri</option>
                            <option value="Transfer BNI">Transfer BNI</option>
                            <option value="E-Wallet (Gopay/OVO/Dana)">E-Wallet (Gopay/OVO/Dana)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Upload Bukti Pembayaran</label>
                        <input type="file" name="bukti_bayar" class="form-control" accept="image/*" required>
                        <small class="text-muted">Format: JPG, PNG, JPEG. Maks: 2MB.</small>
                    </div>
                </div>
            </div>

            <!-- Ringkasan Pesanan -->
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 rounded-4" style="background-color: var(--color-softpink);">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Ringkasan Pesanan</h5>
                        
                        <div class="mb-4" style="max-height: 250px; overflow-y: auto;">
                            <% cart.forEach(item => { %>
                                <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom border-white">
                                    <div class="d-flex align-items-center">
                                        <div class="position-relative">
                                            <img src="<%= item.gambar %>" class="rounded-3" style="width: 50px; height: 50px; object-fit: cover;">
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary" style="font-size: 0.7rem;">
                                                <%= item.qty %>
                                            </span>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0 text-truncate" style="max-width: 150px;"><%= item.nama %></h6>
                                            <small class="text-muted">Rp <%= item.harga.toLocaleString('id-ID') %></small>
                                        </div>
                                    </div>
                                    <div class="fw-bold">
                                        Rp <%= item.subtotal.toLocaleString('id-ID') %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <div class="d-flex justify-content-between mb-3 pt-2">
                            <span class="fs-5">Total Tagihan</span>
                            <span class="fs-4 fw-bold" style="color: var(--color-rosegold);">
                                Rp <%= total.toLocaleString('id-ID') %>
                            </span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold mt-2">
                            Konfirmasi Pembayaran
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<%- include('../layouts/footer') %>