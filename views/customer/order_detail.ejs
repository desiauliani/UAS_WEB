<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container py-5 fade-in">
    <div class="mb-4">
        <a href="/orders/history" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left"></i> Kembali ke Riwayat
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4" style="border-top: 5px solid var(--color-rosegold);">
                <div class="card-body p-5">
                    
                    <!-- Header Invoice -->
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-4">
                        <div>
                            <h3 style="font-family: 'Playfair Display', serif; color: var(--color-rosegold); margin-bottom: 0;">
                                <i class="bi bi-flower1"></i> RHOPALOCERAZ
                            </h3>
                            <p class="text-muted small mt-1 mb-0">Premium Florist E-Commerce</p>
                        </div>
                        <div class="text-end">
                            <h5 class="fw-bold mb-1">#ORD-<%= order.id %></h5>
                            <p class="text-muted small mb-0"><%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute:'2-digit' }) %></p>
                        </div>
                    </div>

                    <!-- Status & Pembayaran -->
                    <div class="row mb-5 bg-light p-4 rounded-3">
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <h6 class="text-muted small text-uppercase mb-2">Metode Pembayaran</h6>
                            <p class="fw-bold mb-0"><i class="bi bi-credit-card me-2"></i> <%= order.metode_pembayaran %></p>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <h6 class="text-muted small text-uppercase mb-2">Status Pesanan</h6>
                            <% 
                                let badgeClass = 'bg-secondary';
                                if(order.status === 'Pending') badgeClass = 'bg-warning text-dark';
                                if(order.status === 'Diproses') badgeClass = 'bg-info text-dark';
                                if(order.status === 'Dikirim') badgeClass = 'bg-primary';
                                if(order.status === 'Selesai') badgeClass = 'bg-success';
                                if(order.status === 'Dibatalkan') badgeClass = 'bg-danger';
                            %>
                            <span class="badge <%= badgeClass %> px-3 py-2 fs-6 rounded-pill"><%= order.status %></span>
                        </div>
                    </div>

                    <!-- Item Detail -->
                    <h6 class="fw-bold mb-3">Rincian Produk</h6>
                    <div class="table-responsive mb-4">
                        <table class="table table-borderless align-middle">
                            <thead class="border-bottom">
                                <tr>
                                    <th class="text-muted font-weight-normal pb-3">Produk</th>
                                    <th class="text-muted font-weight-normal pb-3 text-center">Harga</th>
                                    <th class="text-muted font-weight-normal pb-3 text-center">Qty</th>
                                    <th class="text-muted font-weight-normal pb-3 text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.orderDetails.forEach(item => { %>
                                    <tr>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="<%= item.product.gambar %>" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                <span class="fw-medium"><%= item.product.nama %></span>
                                            </div>
                                        </td>
                                        <td class="py-3 text-center text-muted">Rp <%= item.product.harga.toLocaleString('id-ID') %></td>
                                        <td class="py-3 text-center"><%= item.qty %></td>
                                        <td class="py-3 text-end fw-bold">Rp <%= item.subtotal.toLocaleString('id-ID') %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Total -->
                    <div class="d-flex justify-content-end border-top pt-4">
                        <div style="width: 300px;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Subtotal Produk</span>
                                <span>Rp <%= order.total.toLocaleString('id-ID') %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Biaya Pengiriman</span>
                                <span>Gratis</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold fs-5">Total Akhir</span>
                                <span class="fw-bold fs-4" style="color: var(--color-rosegold);">Rp <%= order.total.toLocaleString('id-ID') %></span>
                            </div>
                        </div>
                    </div>

                    <% if (order.status === 'Selesai') { %>
                        <div class="alert alert-success mt-5 text-center rounded-3">
                            <i class="bi bi-check-circle-fill me-2"></i> Pesanan ini telah selesai. Terima kasih telah berbelanja di Rhopaloceraz!
                        </div>
                    <% } %>

                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>